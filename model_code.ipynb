os.makedirs(KEYPOINTS_DIR, exist_ok=True)

# augmentation settings (applied ONLY on TRAIN split)
MIN_VIDEOS_FOR_NO_AUG = 3
NUM_AUG_PER_VIDEO = 4
TARGET_PER_CLASS = 8
ENABLE_DUPLICATION = True

# training
EPOCH_LIMIT = 50
TRAIN_BATCH_SIZE = 4
EARLY_STOP_PATIENCE = 6
SEED_VALUE = 42

# sequence processing
FEATURE_SIZE = 126
SEQUENCE_LENGTH = 100 

# prediction unknown logic
CONF_THRESHOLD = 0.60
CONF_MARGIN = 0.15

np.random.seed(SEED_VALUE)
tf.random.set_seed(SEED_VALUE)

# ----------------------------
# LABEL EXTRACTION
# ----------------------------
def extract_label_from_filename(filename: str) -> str:
    base_name = os.path.basename(filename)
    first_part = base_name.split('-', 1)[0]
    first_part = re.sub(r'\(.*?\)', '', first_part)
    first_part = re.sub(r'[^A-Za-z0-9ÄÖÅäöåÜüÉéĄąŁłŚśĆćŻżŹź\- ]+', '', first_part)
    return first_part.strip().upper()

# ----------------------------
# AUGMENTATION
# ----------------------------
def save_clip_temp(clip: VideoFileClip, output_path: str) -> str:
    clip.write_videofile(output_path, codec="libx264", audio=False, verbose=False, logger=None)
    return output_path

def create_augmented_paths(video_path: str):
    video_clip = VideoFileClip(video_path)
    temp_dir = tempfile.gettempdir()
    base_name = os.path.splitext(os.path.basename(video_path))[0]

    generated_paths = []

    # original
    original_path = os.path.join(temp_dir, f"{base_name}_orig.mp4")
    save_clip_temp(video_clip, original_path)
    generated_paths.append(original_path)

    # augmentations
    augmentation_ops = [
        lambda c: c.fx(vfx.colorx, 1.25),
        lambda c: c.fx(vfx.colorx, 0.75),
        lambda c: c.fx(vfx.speedx, 1.2),
        lambda c: c.fx(vfx.speedx, 0.85),
    ]

    for i in range(NUM_AUG_PER_VIDEO):
        aug_clip = augmentation_ops[i % len(augmentation_ops)](video_clip)
        temp_path = os.path.join(temp_dir, f"{base_name}_aug_{i}.mp4")
        save_clip_temp(aug_clip, temp_path)
        generated_paths.append(temp_path)

    video_clip.close()
    return generated_paths

# ----------------------------
# MEDIAPIPE KEYPOINT EXTRACTION
# ----------------------------
mp_hands = mp.solutions.hands

def extract_keypoints(video_path, max_frames=None):
    capture = cv2.VideoCapture(video_path)
    sequence = []

    with mp_hands.Hands(
        static_image_mode=False,
        max_num_hands=2,
        min_detection_confidence=0.5,
        min_tracking_confidence=0.5
    ) as hands:
        frame_count = 0
        while True:
            ret, frame = capture.read()
            if not ret:
                break

            frame_count += 1
            if max_frames and frame_count > max_frames:
                break

            rgb = cv2.cvtColor(frame, cv2.COLOR_BGR2RGB)
            results = hands.process(rgb)

            left_hand = np.zeros((21, 3), dtype=np.float32)
            right_hand = np.zeros((21, 3), dtype=np.float32)

            if results.multi_hand_landmarks and results.multi_handedness:
                for lm, handedness in zip(results.multi_hand_landmarks, results.multi_handedness):
                    coords = np.array([[p.x, p.y, p.z] for p in lm.landmark], dtype=np.float32)
                    if handedness.classification[0].label.lower().startswith("left"):
                        left_hand = coords
                    else:
                        right_hand = coords

            sequence.append(np.concatenate([left_hand.flatten(), right_hand.flatten()]))

    capture.release()
    return np.array(sequence, dtype=np.float32)

# ----------------------------
# KEYPOINT NORMALIZATION
# ----------------------------
def normalize_keypoints(seq_data):
    if seq_data.shape[0] == 0:
        return seq_data

    reshaped = seq_data.reshape((-1, 2, 21, 3))
    normalized = np.zeros_like(reshaped, dtype=np.float32)

    for h in range(2):
        hand = reshaped[:, h, :, :]
        wrist = hand[:, 0:1, :]
        centered = hand - wrist

        scale = np.linalg.norm(centered[:, 9, :], axis=1, keepdims=True)
        scale = np.clip(scale, 1e-6, None)

        scaled = centered / scale[:, None, :]
        normalized[:, h, :, :] = scaled

    return normalized.reshape((-1, 126)).astype(np.float32)

# ----------------------------
# FIXED LENGTH SAMPLING
# ----------------------------
def adjust_sequence_length(seq, target_len=SEQUENCE_LENGTH):
    length = seq.shape[0]
    if length == 0:
        return np.zeros((target_len, FEATURE_SIZE), dtype=np.float32)
    if length == target_len:
        return seq.astype(np.float32)
    if length > target_len:
        indices = np.linspace(0, length - 1, target_len).astype(int)
        return seq[indices].astype(np.float32)

    padding = np.zeros((target_len - length, FEATURE_SIZE), dtype=np.float32)
    return np.concatenate([seq.astype(np.float32), padding], axis=0)

# ----------------------------
# STEP A: LOAD + SPLIT
# ----------------------------
video_list = sorted([f for f in os.listdir(VIDEO_DIR)
                     if f.lower().endswith(('.mp4', '.avi', '.mov', '.mkv'))])

original_data = [(os.path.join(VIDEO_DIR, f), extract_label_from_filename(f)) for f in video_list]
labels_only = [lbl for _, lbl in original_data]
label_counts = Counter(labels_only)

if len(original_data) == 0:
    raise RuntimeError(f"No videos found in {VIDEO_DIR}")

can_use_stratify = min(label_counts.values()) >= 2

train_data, val_data = train_test_split(
    original_data,
    test_size=0.2,
    random_state=SEED_VALUE,
    stratify=labels_only if can_use_stratify else None
)

print("Original train videos:", len(train_data))
print("Original val videos:", len(val_data))

# ----------------------------
# STEP B: AUGMENTATION HANDLING
# ----------------------------
train_processing_list = []
for path, label in train_data:
    if label_counts[label] < MIN_VIDEOS_FOR_NO_AUG:
        aug_paths = create_augmented_paths(path)
        for p in aug_paths:
            train_processing_list.append((p, label))

        if ENABLE_DUPLICATION and len(aug_paths) < TARGET_PER_CLASS:
            repeats = math.ceil(TARGET_PER_CLASS / len(aug_paths))
            for _ in range(repeats - 1):
                for p in aug_paths:
                    train_processing_list.append((p, label))
    else:
        train_processing_list.append((path, label))

val_processing_list = [(p, l) for p, l in val_data]

# ----------------------------
# STEP C: PROCESS + SAVE
# ----------------------------
def process_dataset(process_list, tag):
    saved_items = []
    for idx, (path, label) in enumerate(process_list):
        base_name = os.path.splitext(os.path.basename(path))[0]
        safe_name = re.sub(r'[^A-Za-z0-9_.\-]+', '_', base_name)
        filename = f"{tag}__{label}__{safe_name}.npy"
        save_path = os.path.join(KEYPOINTS_DIR, filename)

        if os.path.exists(save_path) and os.path.getsize(save_path) > 0:
            saved_items.append((save_path, label))
            continue

        print(f"[{tag} {idx+1}/{len(process_list)}] {path}")
        seq = extract_keypoints(path)

        if seq.shape[0] == 0:
            print("  -> no keypoints detected, skipping")
            continue

        seq = normalize_keypoints(seq)
        seq = adjust_sequence_length(seq, SEQUENCE_LENGTH)

        np.save(save_path, seq.astype(np.float32))
        saved_items.append((save_path, label))

    return saved_items

saved_train = process_dataset(train_processing_list, "train")
saved_val = process_dataset(val_processing_list, "val")

# ----------------------------
# STEP D: DATASET BUILD
# ----------------------------
X_train_data, y_train_data = [], []
for p, label in saved_train:
    X_train_data.append(np.load(p).astype(np.float32))
    y_train_data.append(label)

X_val_data, y_val_data = [], []
for p, label in saved_val:
    X_val_data.append(np.load(p).astype(np.float32))
    y_val_data.append(label)

label_encoder = LabelEncoder()
y_train_enc = label_encoder.fit_transform(y_train_data)
y_val_enc = label_encoder.transform(y_val_data)

num_classes = len(label_encoder.classes_)

X_train = np.stack(X_train_data, axis=0)
X_val = np.stack(X_val_data, axis=0)

y_train = to_categorical(y_train_enc, num_classes=num_classes).astype(np.float32)
y_val = to_categorical(y_val_enc, num_classes=num_classes).astype(np.float32)

# ----------------------------
# STEP E: MODEL
# ----------------------------
model = Sequential([
    Masking(mask_value=0.0, input_shape=(SEQUENCE_LENGTH, FEATURE_SIZE)),
    LSTM(64),
    Dropout(0.3),
    Dense(32, activation="relu"),
    Dropout(0.2),
    Dense(num_classes, activation="softmax"),
])

model.compile(optimizer="adam", loss="categorical_crossentropy", metrics=["accuracy"])

callbacks = [
    EarlyStopping(monitor="val_loss", patience=EARLY_STOP_PATIENCE, restore_best_weights=True, verbose=1),
    ModelCheckpoint("best_model.h5", monitor="val_loss", save_best_only=True, verbose=1),
]

history = model.fit(
    X_train, y_train,
    validation_data=(X_val, y_val),
    epochs=EPOCH_LIMIT,
    batch_size=TRAIN_BATCH_SIZE,
    callbacks=callbacks,
    shuffle=True,
    verbose=1
)

# ----------------------------
# STEP F: SAVE
# ----------------------------
model.save("final_model.h5")

with open("label_encoder.pkl", "wb") as f:
    pickle.dump(label_encoder, f)

meta_info = {
    "sequence_length": SEQUENCE_LENGTH,
    "feature_size": FEATURE_SIZE,
    "confidence_threshold": CONF_THRESHOLD,
    "confidence_margin": CONF_MARGIN
}

with open("model_meta.json", "w", encoding="utf-8") as f:
    json.dump(meta_info, f, ensure_ascii=False, indent=2)

# ----------------------------
# STEP G: PREDICTION
# ----------------------------
def predict_video(video_path, threshold=CONF_THRESHOLD, margin=CONF_MARGIN):
    seq = extract_keypoints(video_path)
    if seq.shape[0] == 0:
        return ("NoKeypoints", 0.0)

    seq = normalize_keypoints(seq)
    seq = adjust_sequence_length(seq, SEQUENCE_LENGTH)

    inp = np.expand_dims(seq, axis=0).astype(np.float32)
    probs = model.predict(inp, verbose=0)[0]

    top1_idx = int(np.argmax(probs))
    top1_conf = float(probs[top1_idx])

    top2_idx = int(np.argsort(probs)[-2])
    top2_conf = float(probs[top2_idx])

    predicted_label = label_encoder.inverse_transform([top1_idx])[0]

    if (top1_conf < threshold) or ((top1_conf - top2_conf) < margin):
        return ("Unknown", top1_conf)

    return (predicted_label, top1_conf)
